{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Menu item synced from iiko or seeded from JSON"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "uid": {
      "type": "integer",
      "required": true,
      "unique": true
    },
    "title": {
      "type": "string",
      "required": true
    },
    "price": {
      "type": "integer",
      "default": 0
    },
    "descr": {
      "type": "text"
    },
    "gallery": {
      "type": "string"
    },
    "category": {
      "type": "string",
      "required": true
    },
    "branch": {
      "type": "enumeration",
      "enum": ["gusto", "aroma"],
      "required": true
    },
    "portion": {
      "type": "integer"
    },
    "editions": {
      "type": "json"
    },
    "sauce": {
      "type": "json"
    }
  }
}
